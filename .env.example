# Runtime
APP_ENV=production
LOG_LEVEL=INFO
LOG_FILE_PATH=/app/var/log/flight-alerts/app.log

# Database
DATABASE_URL=postgresql+psycopg://flight_alerts:flight_alerts@db:5432/flight_alerts
POSTGRES_PASSWORD=flight_alerts

# Admin API
ADMIN_API_TOKEN=change-me

# Telegram bot
TELEGRAM_BOT_TOKEN=change-me
# Numeric Telegram user IDs, comma-separated.
TELEGRAM_ALLOWED_USER_IDS=123456789

# Travelpayouts / Aviasales Data API
TRAVELPAYOUTS_API_TOKEN=change-me
TRAVELPAYOUTS_BASE_URL=https://api.travelpayouts.com
TRAVELPAYOUTS_LOCALE=ru
TRAVELPAYOUTS_DEFAULT_MARKET=ru
TRAVELPAYOUTS_DEFAULT_CURRENCY=RUB

# HTTP client
HTTP_TIMEOUT_SECONDS=10
HTTP_MAX_RETRIES=3
HTTP_RETRY_BACKOFF_SECONDS=1.5

# Scheduler and alerting
DEFAULT_CHECK_INTERVAL_MINUTES=60
SCHEDULER_TICK_SECONDS=60
MAX_CONCURRENT_CHECKS=3
STORED_OFFERS_PER_CHECK=3
SEARCH_CACHE_TTL_SECONDS=1800
ALERT_COOLDOWN_HOURS=12
MIN_PRICE_DROP_ABS=500
MIN_PRICE_DROP_PCT=5

# Storage / retention
API_CACHE_RETENTION_DAYS=3
SUBSCRIPTION_CHECKS_RETENTION_DAYS=30
NOTIFICATION_EVENTS_RETENTION_DAYS=90
OFFER_PRICE_DETAIL_RETENTION_DAYS=45
OFFER_PRICE_DAILY_RETENTION_DAYS=365
HISTORY_CONTEXT_DAYS=30
CLEANUP_BATCH_SIZE=1000
STORE_RAW_PAYLOAD=false
